<?xml version="1.0" encoding="UTF-8"?>
<PublicationDelivery xmlns="http://www.netex.org.uk/netex"
                     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                     version="2.0">

  <!-- Ofte mandatory i profiler/utvekslingsmetodikk (Entur/Nordic): -->
  <PublicationTimestamp>2026-03-04T10:00:00+01:00</PublicationTimestamp>
  <ParticipantRef>NO:ORG:ExampleProducer</ParticipantRef>

  <dataObjects>
    <CompositeFrame id="NO:CompositeFrame:EXAMPLE:1" version="1">
      <frames>

        <!-- ResponsibilitySet skal ligge i ResourceFrame -->
       <ResourceFrame xmlns="http://www.netex.org.uk/netex"
               id="NO:ResourceFrame:RESOURCES:1"
               version="1">

  <!-- (Valgfritt/nyttig) Definer organisasjonene du refererer til -->
  <organisations>
    <Operator id="NO:Organisation:OPERATOR:1" version="1">
      <Name>Eksempel Operatør AS</Name>
    </Operator>
    <Authority id="NO:Organisation:AUTHORITY:1" version="1">
      <Name>Eksempel Myndighet</Name>
    </Authority>
  </organisations>

  <responsibilitySets>
    <ResponsibilitySet id="NO:ResponsibilitySet:EXAMPLE:1" version="1">
      <Name>Eksempel ansvarsett</Name>

      <!-- ✅ RIKTIG KONTAINER: 'roles' (ikke responsibilityRoleAssignments) -->
      <roles>
        <ResponsibilityRoleAssignment id="NO:RespRoleAssignment:1" version="1">
          <!-- Du kan bruke enten DataRoleType (som i offisielle eksempler),
               eller ResponsibilityRoleRef dersom du modellerer egne roller -->
          <DataRoleType>collects</DataRoleType>
          <ResponsibleOrganisationRef ref="NO:Organisation:OPERATOR:1" version="1"/>
        </ResponsibilityRoleAssignment>

        <ResponsibilityRoleAssignment id="NO:RespRoleAssignment:2" version="1">
          <DataRoleType>publishes</DataRoleType>
          <ResponsibleOrganisationRef ref="NO:Organisation:AUTHORITY:1" version="1"/>
        </ResponsibilityRoleAssignment>
      </roles>
    </ResponsibilitySet>
  </responsibilitySets>
</ResourceFrame>
      </frames>
    </CompositeFrame>
  </dataObjects>
</PublicationDelivery>
