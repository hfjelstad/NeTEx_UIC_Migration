<?xml version="1.0" encoding="UTF-8"?>
<!--
  Example_Accessibility.xml

  Demonstrates accessibility modelling at a rail station:
  - StopPlace-level AccessibilityAssessment (general station accessibility)
  - Quay-level AccessibilityAssessment (per-platform, one accessible, one not)
  - Equipment: ShelterEquipment on accessible quay
  - PathLinks: three segments (entrance to hall, hall to lift, lift to platform)
  - AccessSpaces: indoor areas (entrance, main hall, lift base) used as path endpoints
  - NavigationPath: a named step-free route from entrance to Platform 1

  Scenario: A small rail station with two platforms.
  Platform 1 is step-free (via lift). Platform 2 requires stairs.
-->
<PublicationDelivery xmlns="http://www.netex.org.uk/netex" version="2.0">
  <PublicationTimestamp>2026-03-18T00:00:00Z</PublicationTimestamp>
  <ParticipantRef>EuPro</ParticipantRef>
  <dataObjects>
    <CompositeFrame id="ERP:CompositeFrame:Access:1" version="1">
      <codespaces>
        <Codespace id="erp">
          <Xmlns>ERP</Xmlns>
          <XmlnsUrl>http://www.europeanprofile.eu/ERP</XmlnsUrl>
        </Codespace>
      </codespaces>
      <FrameDefaults>
        <DefaultCodespaceRef ref="erp"/>
      </FrameDefaults>
      <frames>

        <SiteFrame id="ERP:SiteFrame:Access:1" version="1">
          <stopPlaces>
            <StopPlace id="ERP:StopPlace:Asker" version="1">
              <Name>Asker stasjon</Name>
              <Centroid>
                <Location>
                  <Longitude>10.434800</Longitude>
                  <Latitude>59.833500</Latitude>
                </Location>
              </Centroid>

              <!-- Station-level accessibility summary -->
              <AccessibilityAssessment id="ERP:AccessibilityAssessment:Asker" version="1">
                <MobilityImpairedAccess>true</MobilityImpairedAccess>
                <limitations>
                  <AccessibilityLimitation>
                    <WheelchairAccess>true</WheelchairAccess>
                    <StepFreeAccess>true</StepFreeAccess>
                    <AudibleSignalsAvailable>true</AudibleSignalsAvailable>
                    <VisualSignsAvailable>true</VisualSignsAvailable>
                  </AccessibilityLimitation>
                </limitations>
              </AccessibilityAssessment>

              <TransportMode>rail</TransportMode>
              <StopPlaceType>railStation</StopPlaceType>

              <quays>
                <!-- Platform 1: fully accessible via lift -->
                <Quay id="ERP:Quay:Asker_Spor1" version="1">
                  <Name>Spor 1</Name>
                  <AccessibilityAssessment id="ERP:AccessibilityAssessment:Spor1" version="1">
                    <MobilityImpairedAccess>true</MobilityImpairedAccess>
                    <limitations>
                      <AccessibilityLimitation>
                        <WheelchairAccess>true</WheelchairAccess>
                        <StepFreeAccess>true</StepFreeAccess>
                      </AccessibilityLimitation>
                    </limitations>
                  </AccessibilityAssessment>
                  <placeEquipments>
                    <ShelterEquipment id="ERP:ShelterEquipment:Spor1" version="1">
                      <Seats>6</Seats>
                      <StepFree>true</StepFree>
                      <Enclosed>false</Enclosed>
                    </ShelterEquipment>
                  </placeEquipments>
                  <PublicCode>1</PublicCode>
                </Quay>

                <!-- Platform 2: stairs only, NOT step-free -->
                <Quay id="ERP:Quay:Asker_Spor2" version="1">
                  <Name>Spor 2</Name>
                  <AccessibilityAssessment id="ERP:AccessibilityAssessment:Spor2" version="1">
                    <MobilityImpairedAccess>false</MobilityImpairedAccess>
                    <limitations>
                      <AccessibilityLimitation>
                        <WheelchairAccess>false</WheelchairAccess>
                        <StepFreeAccess>false</StepFreeAccess>
                      </AccessibilityLimitation>
                    </limitations>
                  </AccessibilityAssessment>
                  <PublicCode>2</PublicCode>
                </Quay>
              </quays>

              <!-- ==========================================
                   INDOOR NAVIGATION: PathLinks and AccessSpaces
                   ========================================== -->
              <accessSpaces>
                <AccessSpace id="ERP:AccessSpace:Entrance" version="1">
                  <Name>Main Entrance</Name>
                </AccessSpace>
                <AccessSpace id="ERP:AccessSpace:MainHall" version="1">
                  <Name>Main Hall</Name>
                </AccessSpace>
                <AccessSpace id="ERP:AccessSpace:LiftBase" version="1">
                  <Name>Lift (ground level)</Name>
                </AccessSpace>
              </accessSpaces>

              <pathLinks>
                <!-- Segment 1: Entrance to Main Hall (flat, accessible) -->
                <SitePathLink id="ERP:PathLink:Entrance_to_Hall" version="1">
                  <Distance>25</Distance>
                  <From>
                    <AccessSpaceRef ref="ERP:AccessSpace:Entrance"/>
                  </From>
                  <To>
                    <AccessSpaceRef ref="ERP:AccessSpace:MainHall"/>
                  </To>
                  <AccessibilityAssessment id="ERP:AccessibilityAssessment:PL_EntrToHall" version="1">
                    <MobilityImpairedAccess>true</MobilityImpairedAccess>
                    <limitations>
                      <AccessibilityLimitation>
                        <WheelchairAccess>true</WheelchairAccess>
                        <StepFreeAccess>true</StepFreeAccess>
                      </AccessibilityLimitation>
                    </limitations>
                  </AccessibilityAssessment>
                  <Covered>indoors</Covered>
                  <TransferDuration>
                    <DefaultDuration>PT1M</DefaultDuration>
                  </TransferDuration>
                </SitePathLink>

                <!-- Segment 2: Main Hall to Lift (flat, accessible) -->
                <SitePathLink id="ERP:PathLink:Hall_to_Lift" version="1">
                  <Distance>15</Distance>
                  <From>
                    <AccessSpaceRef ref="ERP:AccessSpace:MainHall"/>
                  </From>
                  <To>
                    <AccessSpaceRef ref="ERP:AccessSpace:LiftBase"/>
                  </To>
                  <AccessibilityAssessment id="ERP:AccessibilityAssessment:PL_HallToLift" version="1">
                    <MobilityImpairedAccess>true</MobilityImpairedAccess>
                    <limitations>
                      <AccessibilityLimitation>
                        <WheelchairAccess>true</WheelchairAccess>
                        <StepFreeAccess>true</StepFreeAccess>
                      </AccessibilityLimitation>
                    </limitations>
                  </AccessibilityAssessment>
                  <Covered>indoors</Covered>
                  <TransferDuration>
                    <DefaultDuration>PT30S</DefaultDuration>
                  </TransferDuration>
                </SitePathLink>

                <!-- Segment 3: Lift to Platform 1 (elevator ride, accessible) -->
                <SitePathLink id="ERP:PathLink:Lift_to_Spor1" version="1">
                  <Distance>5</Distance>
                  <From>
                    <AccessSpaceRef ref="ERP:AccessSpace:LiftBase"/>
                  </From>
                  <To>
                    <QuayRef ref="ERP:Quay:Asker_Spor1"/>
                  </To>
                  <AccessibilityAssessment id="ERP:AccessibilityAssessment:PL_LiftToSpor1" version="1">
                    <MobilityImpairedAccess>true</MobilityImpairedAccess>
                    <limitations>
                      <AccessibilityLimitation>
                        <WheelchairAccess>true</WheelchairAccess>
                        <StepFreeAccess>true</StepFreeAccess>
                      </AccessibilityLimitation>
                    </limitations>
                  </AccessibilityAssessment>
                  <Covered>indoors</Covered>
                  <TransferDuration>
                    <DefaultDuration>PT1M30S</DefaultDuration>
                  </TransferDuration>
                </SitePathLink>
              </pathLinks>

              <!-- ==========================================
                   NAVIGATION PATH: Named step-free route
                   ========================================== -->
              <navigationPaths>
                <NavigationPath id="ERP:NavigationPath:Entrance_to_Spor1_StepFree" version="1">
                  <Name>Main entrance to Platform 1 (step-free via lift)</Name>
                  <AccessibilityAssessment id="ERP:AccessibilityAssessment:NP_StepFree" version="1">
                    <MobilityImpairedAccess>true</MobilityImpairedAccess>
                    <limitations>
                      <AccessibilityLimitation>
                        <WheelchairAccess>true</WheelchairAccess>
                        <StepFreeAccess>true</StepFreeAccess>
                      </AccessibilityLimitation>
                    </limitations>
                  </AccessibilityAssessment>
                  <TransferDuration>
                    <DefaultDuration>PT3M</DefaultDuration>
                  </TransferDuration>
                  <pathLinksInSequence>
                    <PathLinkInSequence id="ERP:PathLinkInSequence:1" version="1" order="1">
                      <PathLinkRef ref="ERP:PathLink:Entrance_to_Hall"/>
                    </PathLinkInSequence>
                    <PathLinkInSequence id="ERP:PathLinkInSequence:2" version="1" order="2">
                      <PathLinkRef ref="ERP:PathLink:Hall_to_Lift"/>
                    </PathLinkInSequence>
                    <PathLinkInSequence id="ERP:PathLinkInSequence:3" version="1" order="3">
                      <PathLinkRef ref="ERP:PathLink:Lift_to_Spor1"/>
                    </PathLinkInSequence>
                  </pathLinksInSequence>
                </NavigationPath>
              </navigationPaths>

            </StopPlace>
          </stopPlaces>
        </SiteFrame>

      </frames>
    </CompositeFrame>
  </dataObjects>
</PublicationDelivery>
