<?xml version="1.0" encoding="UTF-8"?>
<!--
  Example_SeparationOfConcerns.xml

  Demonstrates the three coupling strategies between the Traveler domain
  (TimetableFrame) and the Vehicle Operations domain (VehicleScheduleFrame):

  1. Weak separation:    Block directly references ServiceJourney via VehicleJourneyRef
  2. Favoring separation: DatedServiceJourney linking ServiceJourney and Block
  3. Strong separation:   Independent link (not yet standardized, shown as concept)

  All three strategies coexist in a single delivery to illustrate the trade-offs.
-->
<PublicationDelivery xmlns="http://www.netex.org.uk/netex" version="2.0">
  <PublicationTimestamp>2026-03-18T00:00:00Z</PublicationTimestamp>
  <ParticipantRef>EuPro</ParticipantRef>
  <dataObjects>
    <CompositeFrame id="ERP:CompositeFrame:SoC:1" version="1">
      <codespaces>
        <Codespace id="erp">
          <Xmlns>ERP</Xmlns>
          <XmlnsUrl>http://www.europeanprofile.eu/ERP</XmlnsUrl>
        </Codespace>
      </codespaces>
      <FrameDefaults>
        <DefaultCodespaceRef ref="erp"/>
      </FrameDefaults>
      <frames>

        <!-- ============================================================
             SHARED RESOURCES
             Organizations and vehicle types used by all domains
             ============================================================ -->
        <ResourceFrame id="ERP:ResourceFrame:SoC:1" version="1">
          <organisations>
            <Operator id="ERP:Operator:GoAhead" version="1">
              <Name>Go-Ahead Nordic</Name>
            </Operator>
          </organisations>
          <vehicleTypes>
            <VehicleType id="ERP:VehicleType:IC_Train" version="1">
              <Name>InterCity Train Set</Name>
              <Description>Electric multiple unit for regional intercity services</Description>
            </VehicleType>
          </vehicleTypes>
        </ResourceFrame>

        <!-- ============================================================
             SERVICE CALENDAR
             Day types and operating days
             ============================================================ -->
        <ServiceCalendarFrame id="ERP:ServiceCalendarFrame:SoC:1" version="1">
          <dayTypes>
            <DayType id="ERP:DayType:Weekday" version="1">
              <Name>Weekdays (Mon-Fri)</Name>
              <properties>
                <PropertyOfDay>
                  <DaysOfWeek>Monday Tuesday Wednesday Thursday Friday</DaysOfWeek>
                </PropertyOfDay>
              </properties>
            </DayType>
          </dayTypes>
          <operatingDays>
            <OperatingDay id="ERP:OperatingDay:2026-03-12" version="1">
              <CalendarDate>2026-03-12</CalendarDate>
            </OperatingDay>
          </operatingDays>
        </ServiceCalendarFrame>

        <!-- ============================================================
             TRAVELER DOMAIN (ServiceFrame + TimetableFrame)
             What the passenger sees: lines, stops, and journey times.
             This domain should remain clean of operational details.
             ============================================================ -->
        <ServiceFrame id="ERP:ServiceFrame:SoC:1" version="1">
          <lines>
            <Line id="ERP:Line:IC601" version="1">
              <Name>IC 601 Oslo – Kristiansand</Name>
              <PublicCode>601</PublicCode>
              <OperatorRef ref="ERP:Operator:GoAhead"/>
            </Line>
          </lines>
        </ServiceFrame>

        <TimetableFrame id="ERP:TimetableFrame:SoC:1" version="1">
          <vehicleJourneys>

            <!--
              STRATEGY 1: WEAK SEPARATION
              ServiceJourney references Line and DayType directly.
              Simple and clear — the traveler domain owns its own references.
              But if the Block needs to know about this journey, either the
              ServiceJourney must add a BlockRef, or the Block must add a
              VehicleJourneyRef — creating a direct coupling between domains.
            -->
            <ServiceJourney id="ERP:ServiceJourney:SJ_001" version="1">
              <Name>IC 601 Morning departure</Name>
              <dayTypes>
                <DayTypeRef ref="ERP:DayType:Weekday"/>
              </dayTypes>
              <LineRef ref="ERP:Line:IC601"/>
            </ServiceJourney>

            <!--
              STRATEGY 2: FAVORING SEPARATION
              DatedServiceJourney links ServiceJourney (traveler domain) to
              Block (vehicle domain) via BlockRef. The object structure could
              support strong separation, but because DatedServiceJourney lives
              in TimetableFrame, the timetable system controls the coupling —
              indirectly favoring the traveler domain.

              Pro:  ServiceJourney stays clean — no direct Block reference.
              Con:  TimetableFrame (traveler domain) owns the coupling object.
              Risk: Semantic overload — DSJ also carries real-time and deviation data.
            -->
            <DatedServiceJourney id="ERP:DatedServiceJourney:DSJ_001" version="1">
              <BlockRef ref="ERP:Block:TB_601"/>
              <ServiceJourneyRef ref="ERP:ServiceJourney:SJ_001"/>
              <OperatingDayRef ref="ERP:OperatingDay:2026-03-12"/>
            </DatedServiceJourney>

          </vehicleJourneys>
        </TimetableFrame>

        <!-- ============================================================
             VEHICLE OPERATIONS DOMAIN (VehicleScheduleFrame)
             What the operator plans: which vehicles run which journeys.
             Kept separate from passenger-facing timetable data.
             ============================================================ -->
        <VehicleScheduleFrame id="ERP:VehicleScheduleFrame:SoC:1" version="1">
          <blocks>
            <Block id="ERP:Block:TB_601" version="1">
              <Name>Block for IC 601 (Oslo – Kristiansand)</Name>
              <Description>Full-day vehicle assignment for the IC 601 service</Description>
              <journeys>
                <!-- Links this Block back to the ServiceJourney (weak coupling) -->
                <VehicleJourneyRef ref="ERP:ServiceJourney:SJ_001"/>
              </journeys>
            </Block>
          </blocks>
        </VehicleScheduleFrame>

        <!--
          STRATEGY 3: STRONG SEPARATION (conceptual)

          An independent link object would connect domains without either
          domain owning the relationship. This pattern is not yet standardized
          in the NeTEx XSD as a dedicated type, but could be modeled as:

          - A profile extension (ServiceBlockAssociation)
          - An ObjectsLink with ValidBetween
          - A GeneralGroupOfEntities with member references

          The key principle: neither ServiceJourney nor Block contains
          the coupling reference. A third, independent object does.

          <ServiceBlockAssociation id="ERP:SBA:SJ1_TB601" version="1">
            <ServiceJourneyRef ref="ERP:ServiceJourney:SJ_001"/>
            <BlockRef ref="ERP:Block:TB_601"/>
            <ValidBetween>
              <FromDate>2026-03-01T00:00:00Z</FromDate>
              <ToDate>2026-12-14T00:00:00Z</ToDate>
            </ValidBetween>
          </ServiceBlockAssociation>
        -->

      </frames>
    </CompositeFrame>
  </dataObjects>
</PublicationDelivery>
